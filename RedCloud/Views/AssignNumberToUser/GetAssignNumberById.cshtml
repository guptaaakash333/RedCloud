@model RedCloud.Domain.Entities.GetAllAssignNumber

@{
    // ViewData["Title"] = "Viewassignednumber";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .status-active {
        color: white;
        background-color: green;
        padding: 0.2rem 0.5rem;
        border-radius: 0.25rem;
    }

    .status-inactive {
        color: white;
        background-color: red;
        padding: 0.2rem 0.5rem;
        border-radius: 0.25rem;
    }

    .admin-details {
        margin-bottom: 30px;
        margin-top: 20px; /* Add some space between sections */
    }

    .card-custom {
        background-color: #f8f9fa; /* Light gray background */
        border-radius: 10px;
        margin-top: 20px;
        margin-left: 120px;
        width: 900px;
    }

    .card-header-custom {
        background-color: #007BFF; /* Dark background for header */
        color: #fff;
        border-radius: 10px 10px 0 0;
        padding: 10px 20px;
    }

        .card-header-custom .logo-text {
            display: flex;
            align-items: center;
        }

            .card-header-custom .logo-text img {
                width: 50px;
                margin-right: 10px;
            }

        .card-header-custom .buttons {
            margin-left: auto;
        }

            .card-header-custom .buttons a {
                color: #fff;
                margin-left: 10px;
            }
</style>

<div class="container mt-5" style="align-content:center">
    <div class="card card-custom">
        <div class="card-header card-header-custom d-flex justify-content-between align-items-center">
            <div class="logo-text">
                <h1 class="ml-2"><i class="fa-solid fa-phone"></i></h1>
                <h5 class="ml-4">View Number</h5>
            </div>
            <div class="buttons">
                <a href="@Url.Action("ViewAllAssignNumberToUser", "AssignNumberToUser")" class="btn btn-outline-light">
                    <h4><i class="fa-solid fa-circle-left"></i></h4>
                </a>
            </div>
        </div>
        <div class="card-body">
            <div class="row" style="margin-left:20px">
                <div class="col-md-6">
                    @Html.HiddenFor(x => x.NumberId)
                    <p>
                        <strong>Status:</strong>
                        <span class="@(Model.StatusType ? "status-active" : "status-inactive")">
                            @(Model.StatusType ? "Active" : "Not Active")
                        </span>
                    </p>
                    <p><strong>Number:</strong> @Html.DisplayFor(model => model.Number)</p>
                    <p><strong>Assigned Type:</strong> @Html.DisplayFor(model => model.AssignedType)</p>
                    <p><strong>Messaging User:</strong> @Html.DisplayFor(model => model.AssignedUser)</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Include jQuery and Bootstrap JS -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.bundle.min.js"></script>
